{
  "expo": {
    "name": "BabyTracking",
    "slug": "babytracking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "babytracking",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0a27"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dyegovnunes.babytracking"
    },
    "android": {
      "package": "com.dyegovnunes.babytracking",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0a27"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "babytracking"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "fbd01347-a001-4c25-807a-61b0e46c4dc3"
      }
    },
    "owner": "dyegovnunes"
  }
}
