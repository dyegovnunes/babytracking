---
import BlogLayout from '../../layouts/BlogLayout.astro'

const SITE = 'https://blog.yayababy.app'
---

<BlogLayout
  title="Yaya+ ativado — Bem-vindo!"
  description="Seu plano Yaya+ foi ativado com sucesso. Baixe o app e comece agora."
  canonicalUrl={`${SITE}/assinar/sucesso`}
  noindex={true}
>

  <section class="min-h-[80vh] flex items-center justify-center px-5 py-20">
    <div class="max-w-md w-full text-center">

      <!-- Ícone -->
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full mb-8 success-icon-wrap">
        <span style="font-size: 36px;">💜</span>
      </div>

      <!-- Headline -->
      <h1 class="font-display font-bold text-3xl md:text-4xl text-yaya-cloud mb-4">
        Bem-vindo ao Yaya+!
      </h1>

      <p class="text-yaya-cloud/60 text-base font-sans leading-relaxed mb-3">
        Seu plano foi ativado com sucesso.
      </p>
      <p class="text-yaya-cloud/50 text-sm font-sans leading-relaxed mb-10">
        Abra o app Yaya e faça login com a mesma conta usada na compra —
        tudo estará desbloqueado automaticamente.
      </p>

      <!-- App badges -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10">
        <a
          href="https://apps.apple.com/app/yaya-baby"
          target="_blank"
          rel="noopener noreferrer"
          class="store-badge"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="text-left">
            <div class="text-[9px] text-white/60 leading-none">Disponível na</div>
            <div class="text-sm font-semibold text-white leading-tight">App Store</div>
          </div>
        </a>

        <a
          href="https://play.google.com/store/apps/details?id=app.yayababy"
          target="_blank"
          rel="noopener noreferrer"
          class="store-badge"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92z" fill="#4285F4"/>
            <path d="M17.556 8.235l-3.764 3.764 3.764 3.765 4.247-2.39a1 1 0 000-1.748l-4.247-2.39z" fill="#FBBC04"/>
            <path d="M3.609 1.814L13.792 12l3.764-3.765-9.72-5.473a1.003 1.003 0 00-4.227-.948z" fill="#34A853"/>
            <path d="M13.792 12L3.61 22.186a1.003 1.003 0 004.227-.948l9.72-5.473L13.791 12z" fill="#EA4335"/>
          </svg>
          <div class="text-left">
            <div class="text-[9px] text-white/60 leading-none">Disponível no</div>
            <div class="text-sm font-semibold text-white leading-tight">Google Play</div>
          </div>
        </a>
      </div>

      <!-- Divider -->
      <div class="flex items-center gap-3 mb-6">
        <div class="flex-1 h-px" style="background: rgba(183,159,255,0.1);"></div>
        <span class="text-yaya-cloud/25 text-xs font-sans">ou</span>
        <div class="flex-1 h-px" style="background: rgba(183,159,255,0.1);"></div>
      </div>

      <!-- Secondary links -->
      <div class="flex flex-col gap-2 items-center">
        <a
          href="/biblioteca-yaya"
          class="text-sm font-sans text-yaya-cloud/50 hover:text-yaya-purple transition-colors"
        >
          Explorar a Biblioteca de Guias →
        </a>
        <a
          href="/assinar"
          class="text-sm font-sans text-yaya-cloud/30 hover:text-yaya-cloud/50 transition-colors"
        >
          Voltar para a página de planos
        </a>
      </div>

    </div>
  </section>

</BlogLayout>

<style>
.success-icon-wrap {
  background: rgba(183,159,255,0.1);
  border: 1px solid rgba(183,159,255,0.2);
}

.store-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 20px;
  border-radius: 12px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(183,159,255,0.15);
  text-decoration: none;
  transition: background 0.2s, border-color 0.2s;
}
.store-badge:hover {
  background: rgba(255,255,255,0.07);
  border-color: rgba(183,159,255,0.3);
}
</style>
