---
import BlogLayout from '../../layouts/BlogLayout.astro'
import { supabase } from '../../lib/supabase'
import type { BlogPost, ContentCategory } from '../../types'
import { CATEGORY_LABEL, CATEGORY_EMOJI } from '../../types'
import { categoryBreadcrumbJsonLd } from '../../lib/jsonld'

const CATEGORIES: ContentCategory[] = [
  'alimentacao', 'sono', 'desenvolvimento', 'saude', 'rotina', 'marcos',
]

export async function getStaticPaths() {
  const cats: ContentCategory[] = [
    'alimentacao', 'sono', 'desenvolvimento', 'saude', 'rotina', 'marcos',
  ]
  return cats.map((c) => ({ params: { categoria: c } }))
}

const { categoria } = Astro.params
const cat = categoria as ContentCategory

const { data: posts, error } = await supabase
  .from('blog_posts')
  .select('id, slug, title, meta_description, category, audience, target_week_start, target_week_end, image_url, published_at')
  .eq('status', 'published')
  .eq('category', cat)
  .order('published_at', { ascending: false })

const allPosts = (posts ?? []) as BlogPost[]

function formatWeekRange(start: number | null, end: number | null): string {
  if (!start) return ''
  if (!end || start === end) return `Semana ${start}`
  return `Semanas ${start}–${end}`
}

const catLabel = CATEGORY_LABEL[cat]
const catEmoji = CATEGORY_EMOJI[cat]
const canonicalUrl = `https://blog.yayababy.app/categoria/${cat}`
const breadcrumbLd = categoryBreadcrumbJsonLd(cat)
---

<BlogLayout
  title={`${catLabel} — Guias para pais | Yaya Baby`}
  description={`Guias práticos sobre ${catLabel.toLowerCase()} do bebê. Conteúdo baseado em evidências, escrito pra pais reais.`}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <!-- Hero da categoria -->
  <section class="max-w-3xl mx-auto px-4 pt-14 pb-10">
    <nav class="text-sm text-yaya-cloud/50 mb-5 flex items-center gap-1.5 font-sans">
      <a href="/" class="hover:text-yaya-cloud transition-colors">Blog</a>
      <span class="text-yaya-cloud/30">›</span>
      <span class="text-yaya-purple font-medium">{catLabel}</span>
    </nav>
    <div class="flex items-center gap-3 mb-4">
      <span class="text-4xl">{catEmoji}</span>
      <h1 class="font-display text-3xl md:text-4xl font-extrabold text-yaya-cloud tracking-tight">
        {catLabel}
      </h1>
    </div>
    <p class="text-yaya-cloud/70 text-lg max-w-xl font-sans leading-relaxed">
      {allPosts.length} {allPosts.length === 1 ? 'guia' : 'guias'} sobre {catLabel.toLowerCase()} do bebê.
    </p>
  </section>

  <!-- Filtro por categoria -->
  <section class="max-w-3xl mx-auto px-4 mb-10">
    <div class="flex flex-wrap gap-2">
      <a
        href="/"
        class="px-3 py-1.5 rounded-md text-sm font-display font-bold bg-yaya-cloud/5 text-yaya-cloud/80 hover:bg-yaya-cloud/10 hover:text-yaya-cloud transition-colors"
      >
        Todos
      </a>
      {CATEGORIES.map((c) => (
        <a
          href={`/categoria/${c}`}
          class:list={[
            'px-3 py-1.5 rounded-md text-sm font-display font-bold transition-colors',
            c === cat
              ? 'bg-yaya-purple text-yaya-night'
              : 'bg-yaya-cloud/5 text-yaya-cloud/80 hover:bg-yaya-cloud/10 hover:text-yaya-cloud',
          ]}
        >
          {CATEGORY_EMOJI[c]} {CATEGORY_LABEL[c]}
        </a>
      ))}
    </div>
  </section>

  <!-- Lista de artigos da categoria -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    {error && (
      <p class="text-yaya-cloud/50 text-center py-20 font-sans">Não conseguimos carregar os artigos agora. Tenta de novo em alguns instantes.</p>
    )}

    {!error && allPosts.length === 0 && (
      <div class="text-center py-24">
        <img src="/symbol.png" alt="Yaya" class="h-14 w-auto mx-auto mb-6 opacity-40" />
        <p class="text-yaya-cloud/60 font-sans text-lg mb-2">Ainda não temos guias nesta categoria.</p>
        <a href="/" class="text-yaya-purple hover:text-yaya-glow font-sans text-sm">Ver todos os guias →</a>
      </div>
    )}

    <div class="space-y-4">
      {allPosts.map((post) => (
        <a
          href={`/${post.slug}`}
          class="group block bg-yaya-cloud/[0.03] rounded-md overflow-hidden border border-yaya-cloud/10 hover:border-yaya-purple/40 hover:bg-yaya-cloud/[0.06] transition-all"
        >
          <div class="flex gap-4 p-5">
            {post.image_url ? (
              <img
                src={post.image_url}
                alt={post.title}
                class="w-24 h-24 rounded-md object-cover shrink-0"
                loading="lazy"
              />
            ) : (
              <div class="w-24 h-24 rounded-md bg-yaya-purple/10 border border-yaya-purple/15 flex items-center justify-center shrink-0">
                <span class="text-3xl">{catEmoji}</span>
              </div>
            )}

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[10px] font-display font-bold text-yaya-purple uppercase tracking-wider">
                  {catLabel}
                </span>
                {post.target_week_start && (
                  <span class="text-[10px] text-yaya-cloud/40 font-sans font-medium">
                    · {formatWeekRange(post.target_week_start, post.target_week_end)}
                  </span>
                )}
              </div>

              <h2 class="font-display font-bold text-yaya-cloud text-base leading-snug mb-2 group-hover:text-yaya-purple transition-colors">
                {post.title}
              </h2>

              {post.meta_description && (
                <p class="text-yaya-cloud/60 text-sm line-clamp-2 leading-relaxed font-sans">
                  {post.meta_description}
                </p>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BlogLayout>
