---
import BlogLayout from '../../../layouts/BlogLayout.astro'

const SITE = 'https://blog.yayababy.app'
const slug = Astro.url.searchParams.get('slug') ?? ''
const readerUrl = slug ? `/sua-biblioteca/${slug}/ler` : '/minha-biblioteca'
---

<BlogLayout
  title="Acesso confirmado — Sua Biblioteca Yaya"
  description="Seu guia está pronto. Verifique seu email para acessar."
  canonicalUrl={`${SITE}/sua-biblioteca/checkout/sucesso`}
  noindex={true}
>
  <section class="success-hero min-h-[80vh] flex items-center justify-center px-4 py-20">
    <div class="max-w-lg w-full text-center">

      <!-- Ícone animado -->
      <div class="success-icon-wrapper mx-auto mb-8">
        <div class="success-ring" />
        <span class="success-icon-inner text-4xl">💌</span>
      </div>

      <!-- Headline -->
      <h1
        class="font-display font-bold text-3xl md:text-4xl text-yaya-cloud mb-4 leading-tight"
      >
        Verifique seu email.
      </h1>

      <!-- Body -->
      <p class="text-yaya-cloud/60 font-sans text-base leading-relaxed mb-3 max-w-sm mx-auto">
        Enviamos um link de acesso para o seu email. Clique nele para entrar direto no guia — sem precisar criar senha.
      </p>
      <p class="text-yaya-cloud/35 font-sans text-sm mb-10">
        Não encontrou? Verifique a pasta de spam ou lixo eletrônico.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        {slug && (
          <a
            href={readerUrl}
            class="inline-block px-7 py-3.5 rounded-xl text-[#0d0a27] font-display font-bold text-sm transition-opacity hover:opacity-90"
            style="background: linear-gradient(135deg, #b79fff, #8b6df0); box-shadow: 0 0 24px rgba(183,159,255,0.3);"
          >
            Já tenho acesso — entrar →
          </a>
        )}
        <a
          href="/sua-biblioteca"
          class="inline-block px-7 py-3.5 rounded-xl text-yaya-cloud/60 font-sans text-sm transition-colors hover:text-yaya-cloud"
          style="border: 1px solid rgba(231,226,255,0.1);"
        >
          Ir para a biblioteca
        </a>
      </div>

      <!-- Nota de cortesia Yaya+ -->
      <div class="mt-12 rounded-xl p-5 max-w-sm mx-auto"
           style="background: rgba(183,159,255,0.06); border: 1px solid rgba(183,159,255,0.15);">
        <p class="text-xs font-display font-bold uppercase tracking-widest mb-2" style="color: rgba(183,159,255,0.75);">✦ Presente da Yaya</p>
        <p class="text-yaya-cloud/55 font-sans text-sm leading-relaxed">
          Junto com o guia, você ganha <strong class="text-yaya-cloud/80">30 dias de Yaya+ grátis</strong> no app.
          Baixe o app Yaya e use o mesmo email para ativar.
        </p>
        <a
          href="https://yayababy.app"
          class="inline-block mt-3 text-xs font-display font-bold transition-opacity hover:opacity-80"
          style="color: rgba(183,159,255,0.8);"
        >
          Baixar o app Yaya →
        </a>
      </div>

    </div>
  </section>
</BlogLayout>

<style>
  .success-hero {
    background: radial-gradient(125% 125% at 50% 0%, #0d0a27 40%, #1a1145);
  }

  /* Ícone com anel pulsante */
  .success-icon-wrapper {
    position: relative;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .success-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(183, 159, 255, 0.4);
    animation: success-ring-pulse 2s ease-out infinite;
  }
  .success-icon-inner {
    position: relative;
    z-index: 1;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(183, 159, 255, 0.1);
    border: 1px solid rgba(183, 159, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: success-icon-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes success-ring-pulse {
    0%   { transform: scale(1);    opacity: 0.6; }
    100% { transform: scale(1.6);  opacity: 0; }
  }
  @keyframes success-icon-in {
    from { transform: scale(0.6); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
</style>
