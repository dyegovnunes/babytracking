---
import BlogLayout from '../layouts/BlogLayout.astro'
import { supabase } from '../lib/supabase'
import type { BlogPost, ContentCategory } from '../types'
import { CATEGORY_LABEL, CATEGORY_EMOJI } from '../types'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data } = await supabase
    .from('blog_posts')
    .select('slug')
    .eq('status', 'published')

  return (data ?? []).map((p) => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params

const { data, error } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'published')
  .single()

if (error || !data) {
  return Astro.redirect('/404')
}

const post = data as BlogPost

marked.setOptions({ breaks: true })
const contentHtml = await marked(post.content_md)

function formatWeekRange(start: number | null, end: number | null): string {
  if (!start) return ''
  if (!end || start === end) return `Semana ${start}`
  return `Semanas ${start}–${end}`
}

const canonicalUrl = `https://blog.yayababy.app/${post.slug}`
const publishDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })
  : null
---

<BlogLayout
  title={post.title}
  description={post.meta_description ?? undefined}
  image={post.image_url ?? undefined}
  canonicalUrl={canonicalUrl}
>
  <!-- Schema markup: Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.title,
    description: post.meta_description,
    image: post.image_url,
    datePublished: post.published_at,
    publisher: {
      '@type': 'Organization',
      name: 'Yaya Baby',
      url: 'https://yayababy.app',
      logo: {
        '@type': 'ImageObject',
        url: 'https://blog.yayababy.app/logo.png',
      },
    },
  })} />

  <article class="max-w-2xl mx-auto px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-yaya-cloud/50 mb-8 flex items-center gap-1.5 font-sans">
      <a href="/" class="hover:text-yaya-cloud transition-colors">Blog</a>
      <span class="text-yaya-cloud/30">›</span>
      <span class="text-yaya-purple font-medium">{CATEGORY_LABEL[post.category as ContentCategory]}</span>
    </nav>

    <!-- Header do artigo -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-2xl">{CATEGORY_EMOJI[post.category as ContentCategory]}</span>
        <span class="text-xs font-display font-bold text-yaya-purple uppercase tracking-wider">
          {CATEGORY_LABEL[post.category as ContentCategory]}
        </span>
        {post.target_week_start && (
          <span class="text-xs text-yaya-cloud/40 font-sans">
            · {formatWeekRange(post.target_week_start, post.target_week_end)}
          </span>
        )}
      </div>

      <h1 class="font-display text-3xl md:text-4xl font-extrabold text-yaya-cloud leading-tight mb-5 tracking-tight">
        {post.title}
      </h1>

      {post.meta_description && (
        <p class="text-yaya-cloud/70 text-lg leading-relaxed mb-5 font-sans">
          {post.meta_description}
        </p>
      )}

      {publishDate && (
        <time class="text-sm text-yaya-cloud/40 font-sans" datetime={post.published_at ?? ''}>
          Publicado em {publishDate}
        </time>
      )}
    </header>

    <!-- Imagem de capa -->
    {post.image_url && (
      <div class="mb-10 rounded-md overflow-hidden border border-yaya-cloud/10">
        <img
          src={post.image_url}
          alt={post.image_alt ?? post.title}
          class="w-full object-cover max-h-80"
        />
      </div>
    )}

    <!-- Corpo do artigo -->
    <div class="prose-yaya" set:html={contentHtml} />

    <!-- Disclaimer -->
    <div class="mt-12 p-4 rounded-md bg-yaya-cloud/[0.03] border border-yaya-cloud/10 text-sm text-yaya-cloud/60 leading-relaxed font-sans">
      <strong class="text-yaya-cloud/80">Aviso:</strong> Este artigo tem caráter educativo e não substitui orientação médica individualizada. Consulte sempre o pediatra do seu bebê.
    </div>

    <!-- CTA baixar app -->
    <div class="mt-10 p-6 rounded-md bg-gradient-to-br from-yaya-purple/15 to-yaya-blush/10 border border-yaya-purple/25 text-center">
      <p class="font-display text-lg font-bold text-yaya-cloud mb-2">Organize a rotina do seu bebê</p>
      <p class="text-yaya-cloud/70 text-sm mb-5 font-sans leading-relaxed">
        Registre amamentação, sono, fraldas e marcos com 1 toque — mesmo às 3 da manhã.
      </p>
      <a
        href="https://yayababy.app"
        class="inline-block bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold px-6 py-3 rounded-md transition-colors"
      >
        Baixar o Yaya grátis
      </a>
    </div>
  </article>
</BlogLayout>

<style is:global>
  /* Prose styles para o conteúdo Markdown — paleta Yaya */
  .prose-yaya {
    color: rgb(231 226 255 / 0.85);
    line-height: 1.75;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1rem;
  }
  .prose-yaya h2 {
    color: rgb(231 226 255);
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.55rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .prose-yaya h3 {
    color: rgb(231 226 255);
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }
  .prose-yaya p {
    margin-bottom: 1.25rem;
  }
  .prose-yaya strong {
    color: rgb(231 226 255);
    font-weight: 700;
  }
  .prose-yaya em {
    color: rgb(231 226 255 / 0.95);
  }
  .prose-yaya ul, .prose-yaya ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-yaya li {
    margin-bottom: 0.4rem;
  }
  .prose-yaya li::marker {
    color: rgb(183 159 255);
  }
  .prose-yaya a {
    color: rgb(183 159 255);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgb(183 159 255 / 0.4);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .prose-yaya a:hover {
    color: rgb(171 143 254);
    text-decoration-color: rgb(171 143 254);
  }
  .prose-yaya blockquote {
    border-left: 3px solid rgb(183 159 255);
    padding-left: 1.25rem;
    color: rgb(231 226 255 / 0.7);
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose-yaya hr {
    border-color: rgb(231 226 255 / 0.1);
    margin: 2.5rem 0;
  }
  .prose-yaya code {
    background: rgb(231 226 255 / 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: rgb(255 150 185);
  }
</style>
