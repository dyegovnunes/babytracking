---
import BlogLayout from '../layouts/BlogLayout.astro'
import { supabase } from '../lib/supabase'
import type { BlogPost, ContentCategory } from '../types'
import { CATEGORY_LABEL, CATEGORY_EMOJI } from '../types'
import { marked } from 'marked'
import {
  breadcrumbJsonLd,
  articleJsonLd,
  howToJsonLd,
  faqJsonLd,
  slugifyHeading,
} from '../lib/jsonld'
import ReadingProgress from '../components/ReadingProgress.astro'
import TableOfContents from '../components/TableOfContents.astro'
import RelatedPosts from '../components/RelatedPosts.astro'
import ShareButtons from '../components/ShareButtons.astro'
import FeedbackBox from '../components/FeedbackBox.astro'
import CorrectionLink from '../components/CorrectionLink.astro'
import PremiumTeaser from '../components/PremiumTeaser.astro'
import NewsletterSignup from '../components/NewsletterSignup.astro'
import AffiliateProducts from '../components/AffiliateProducts.astro'

export async function getStaticPaths() {
  const { data } = await supabase
    .from('blog_posts')
    .select('slug')
    .eq('status', 'published')

  return (data ?? []).map((p) => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params

const { data, error } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'published')
  .single()

if (error || !data) {
  return Astro.redirect('/404')
}

const post = data as BlogPost

// Pre-processa markdown:
// - Remove "## Leia também" (renderizado via componente RelatedPosts com cards)
// - Remove "## Sumário" (renderizado via TableOfContents auto-gerado)
const cleanedMd = post.content_md
  .replace(/##\s*Leia também[\s\S]*?\n---\n/gi, '')
  .replace(/##\s*Sumário[\s\S]*?(?=\n##\s)/gi, '')

// gfm: true (padrão) habilita tabelas, strikethrough, etc.
// breaks: false (removido) permite parsing correto de listas e tabelas
// mesmo quando precedidas por texto sem linha em branco.
marked.setOptions({ gfm: true })
const rawHtml = await marked(cleanedMd)

// 1) Adiciona id="..." em cada <h2> para as âncoras do TOC funcionarem
// 2) Abre links externos (http/https) em nova aba com rel noopener
const contentHtml = rawHtml
  .replace(
    /<h2>(.+?)<\/h2>/g,
    (_, inner) => {
      const text = inner.replace(/<[^>]+>/g, '')
      return `<h2 id="${slugifyHeading(text)}">${inner}</h2>`
    },
  )
  .replace(
    /<a href="(https?:\/\/[^"]+)"/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer"',
  )

// Injeta imagem do meio do artigo após o 2º H2
const h2Matches = [...contentHtml.matchAll(/<h2[ >]/g)]
let contentTop = contentHtml
let contentBottom = ''
if (post.mid_image_url && h2Matches.length >= 2) {
  const splitIdx = h2Matches[1].index!
  contentTop = contentHtml.slice(0, splitIdx)
  contentBottom = contentHtml.slice(splitIdx)
}

// Extrai lista de headings H2 para o TOC
const h2Headings: string[] = (cleanedMd.match(/^## (.+)$/gm) ?? []).map(
  (l) => l.replace(/^## /, '').trim(),
)

// Reading time — baseado em palavras / 200wpm (leitura média em PT-BR)
const wordCount = post.content_md
  .replace(/[#*`>\-_\[\]()]/g, '')
  .split(/\s+/)
  .filter(Boolean).length
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200))

// Related posts — busca dados básicos dos slugs marcados + preserva ordem editorial
let relatedPosts: BlogPost[] = []
if (post.related_slugs && post.related_slugs.length > 0) {
  const { data: related } = await supabase
    .from('blog_posts')
    .select('slug, title, meta_description, category, image_url')
    .in('slug', post.related_slugs.slice(0, 3))
    .eq('status', 'published')
  const byslug = new Map((related ?? []).map((r: any) => [r.slug, r as BlogPost]))
  relatedPosts = post.related_slugs
    .slice(0, 3)
    .map((s) => byslug.get(s))
    .filter((p): p is BlogPost => !!p)
}

function formatWeekRange(start: number | null, end: number | null): string {
  // Esconde quando start é 0, null ou inválido (evita "Semanas 0–X")
  if (!start || start <= 0) return ''
  if (!end || start === end) return `Semana ${start}`
  return `Semanas ${start}–${end}`
}

const canonicalUrl = `https://blog.yayababy.app/${post.slug}`
const publishDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })
  : null

// Structured data: sempre BreadcrumbList + Article. Quando o post é HowTo ou
// FAQPage, emite também o schema especializado para rich results no Google.
const breadcrumbLd = breadcrumbJsonLd(post)
const articleLd = articleJsonLd(post)
const howToLd = post.schema_type === 'HowTo' ? howToJsonLd(post) : null
const faqLd = post.schema_type === 'FAQPage' ? faqJsonLd(post) : null
---

<BlogLayout
  title={post.title}
  description={post.meta_description ?? undefined}
  image={post.image_url ?? undefined}
  canonicalUrl={canonicalUrl}
>
  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  {howToLd && <script type="application/ld+json" set:html={JSON.stringify(howToLd)} />}
  {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

  <!-- Barra de progresso da leitura -->
  <ReadingProgress />

  <article class="max-w-2xl mx-auto px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-yaya-cloud/50 mb-8 flex items-center gap-1.5 font-sans">
      <a href="/" class="hover:text-yaya-cloud transition-colors">Blog</a>
      <span class="text-yaya-cloud/30">›</span>
      <span class="text-yaya-purple font-medium">{CATEGORY_LABEL[post.category as ContentCategory]}</span>
    </nav>

    <!-- Header do artigo -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-5 flex-wrap">
        <span class="text-2xl">{CATEGORY_EMOJI[post.category as ContentCategory]}</span>
        <span class="text-xs font-display font-bold text-yaya-purple uppercase tracking-wider">
          {CATEGORY_LABEL[post.category as ContentCategory]}
        </span>
        {post.post_number != null && (
          <span class="text-xs text-yaya-cloud/40 font-sans tabular-nums">
            · #{String(post.post_number).padStart(2, '0')}
          </span>
        )}
        {formatWeekRange(post.target_week_start, post.target_week_end) && (
          <span class="text-xs text-yaya-cloud/40 font-sans">
            · {formatWeekRange(post.target_week_start, post.target_week_end)}
          </span>
        )}
      </div>

      <h1 class="font-display text-3xl md:text-4xl font-extrabold text-yaya-cloud leading-tight mb-5 tracking-tight">
        {post.title}
      </h1>

      {post.meta_description && (
        <p class="text-yaya-cloud/70 text-lg leading-relaxed mb-5 font-sans">
          {post.meta_description}
        </p>
      )}

      <div class="flex items-center gap-3 text-sm text-yaya-cloud/40 font-sans mb-6">
        {publishDate && (
          <time datetime={post.published_at ?? ''}>
            {publishDate}
          </time>
        )}
        <span class="text-yaya-cloud/20">·</span>
        <span class="flex items-center gap-1">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {readingMinutes} min de leitura
        </span>
      </div>

      <!-- Share buttons no topo do artigo -->
      <ShareButtons title={post.title} url={canonicalUrl} audience={post.audience} />
    </header>

    <!-- Imagem de capa -->
    {post.image_url && (
      <div class="mb-10 rounded-md overflow-hidden border border-yaya-cloud/10">
        <img
          src={post.image_url}
          alt={post.image_alt ?? post.title}
          class="w-full object-cover max-h-80"
        />
      </div>
    )}

    <!-- Tabela de conteúdo (só em artigos com 6+ seções) -->
    <TableOfContents headings={h2Headings} />

    <!-- Corpo do artigo -->
    <div class="prose-yaya" set:html={contentTop} />
    {post.mid_image_url && contentBottom && (
      <div class="my-8 rounded-md overflow-hidden border border-yaya-cloud/10">
        <img
          src={post.mid_image_url}
          alt={post.image_alt ?? post.title}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    )}
    {contentBottom && <div class="prose-yaya" set:html={contentBottom} />}

    <!-- Produtos afiliados (só aparece quando o post tem produtos cadastrados) -->
    <AffiliateProducts products={post.affiliate_products ?? []} />

    <!-- Leia também: logo após o corpo do artigo, formato em cards -->
    <RelatedPosts posts={relatedPosts} />

    <!-- Premium teaser (opcional, editor marca no frontmatter) -->
    <PremiumTeaser teaser={post.premium_teaser} />

    <!-- Newsletter signup inline pós-artigo -->
    <NewsletterSignup source={`blog-post-${post.slug}`} variant="article" />

    <!-- Disclaimer -->
    <div class="mt-12 p-4 rounded-md bg-yaya-cloud/[0.03] border border-yaya-cloud/10 text-sm text-yaya-cloud/60 leading-relaxed font-sans">
      <strong class="text-yaya-cloud/80">Aviso:</strong> Este artigo tem caráter educativo e não substitui orientação médica individualizada. Consulte sempre o pediatra do seu bebê.
    </div>

    <!-- CTA baixar app — condicional por audience -->
    {post.audience === 'gestante' ? (
      <div class="mt-10 p-6 rounded-md bg-gradient-to-br from-yaya-purple/15 to-yaya-blush/10 border border-yaya-purple/25 text-center">
        <p class="font-display text-lg font-bold text-yaya-cloud mb-2">Prepare-se pra chegada do bebê</p>
        <p class="text-yaya-cloud/70 text-sm mb-5 font-sans leading-relaxed">
          Baixe o Yaya agora e tenha tudo pronto pro primeiro dia: rotina, amamentação, sono, marcos — com 1 toque.
        </p>
        <a
          href="https://yayababy.app"
          class="inline-block bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold px-6 py-3 rounded-md transition-colors"
        >
          Deixar o Yaya instalado
        </a>
        <p class="text-yaya-cloud/40 text-xs mt-3 font-sans">Grátis · Android e iOS</p>
      </div>
    ) : (
      <div class="mt-10 p-6 rounded-md bg-gradient-to-br from-yaya-purple/15 to-yaya-blush/10 border border-yaya-purple/25 text-center">
        <p class="font-display text-lg font-bold text-yaya-cloud mb-2">Organize a rotina do seu bebê</p>
        <p class="text-yaya-cloud/70 text-sm mb-5 font-sans leading-relaxed">
          Registre amamentação, sono, fraldas e marcos com 1 toque.
        </p>
        <a
          href="https://yayababy.app"
          class="inline-block bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold px-6 py-3 rounded-md transition-colors"
        >
          Baixar o Yaya grátis
        </a>
        <p class="text-yaya-cloud/40 text-xs mt-3 font-sans">Grátis · Android e iOS</p>
      </div>
    )}

    <!-- Feedback (CSAT 👍/👎 + incentivo a compartilhar) -->
    <FeedbackBox
      slug={post.slug}
      title={post.title}
      url={canonicalUrl}
      audience={post.audience}
      relatedSlugs={post.related_slugs ?? []}
    />

    <!-- Link de correção -->
    <CorrectionLink title={post.title} url={canonicalUrl} />
  </article>
</BlogLayout>

<style is:global>
  /* Prose styles — usa CSS vars pra reagir ao light/dark mode */
  .prose-yaya {
    color: rgb(var(--yaya-cloud) / 0.85);
    line-height: 1.75;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 0.95rem;
  }
  @media (min-width: 640px) {
    .prose-yaya {
      font-size: 1rem;
    }
  }
  .prose-yaya h2 {
    color: rgb(var(--yaya-cloud));
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.55rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    /* Compensa o header sticky (~60px) pra o anchor jump da TOC parar
       no lugar certo. Se o header crescer, aumentar esse valor. */
    scroll-margin-top: 80px;
  }
  .prose-yaya h3 {
    color: rgb(var(--yaya-cloud));
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
    scroll-margin-top: 80px;
  }
  .prose-yaya p {
    margin-bottom: 1.25rem;
  }
  .prose-yaya strong {
    color: rgb(var(--yaya-cloud));
    font-weight: 700;
  }
  .prose-yaya em {
    color: rgb(var(--yaya-cloud) / 0.95);
  }
  .prose-yaya ul, .prose-yaya ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  /* Tailwind Preflight remove list-style-type. Reativamos aqui. */
  .prose-yaya ul {
    list-style-type: disc;
  }
  .prose-yaya ol {
    list-style-type: decimal;
  }
  .prose-yaya ul ul {
    list-style-type: circle;
  }
  .prose-yaya li {
    margin-bottom: 0.4rem;
  }
  .prose-yaya li::marker {
    color: rgb(var(--yaya-purple));
  }
  .prose-yaya a {
    color: rgb(var(--yaya-purple));
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgb(var(--yaya-purple) / 0.4);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .prose-yaya a:hover {
    color: rgb(var(--yaya-glow));
    text-decoration-color: rgb(var(--yaya-glow));
  }
  .prose-yaya blockquote {
    border-left: 3px solid rgb(var(--yaya-purple));
    padding-left: 1.25rem;
    color: rgb(var(--yaya-cloud) / 0.7);
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose-yaya hr {
    border-color: rgb(var(--yaya-cloud) / 0.1);
    margin: 2.5rem 0;
  }
  .prose-yaya code {
    background: rgb(var(--yaya-cloud) / 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: rgb(var(--yaya-blush));
  }

  /* ── Tabelas ─────────────────────────────────────────────── */
  /* Wrapper p/ scroll horizontal quando a tabela é larga demais pra mobile */
  .prose-yaya table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid rgb(var(--yaya-cloud) / 0.1);
    border-radius: 6px;
  }
  .prose-yaya thead {
    background: rgb(var(--yaya-cloud) / 0.05);
  }
  .prose-yaya th {
    color: rgb(var(--yaya-cloud));
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.7rem 0.9rem;
    text-align: left;
    border-bottom: 1px solid rgb(var(--yaya-cloud) / 0.15);
    white-space: nowrap;
  }
  .prose-yaya td {
    padding: 0.7rem 0.9rem;
    font-size: 0.9rem;
    border-bottom: 1px solid rgb(var(--yaya-cloud) / 0.07);
    vertical-align: top;
  }
  .prose-yaya tbody tr:last-child td {
    border-bottom: none;
  }
  .prose-yaya tbody tr:hover {
    background: rgb(var(--yaya-cloud) / 0.03);
  }
</style>
