---
import BlogLayout from '../../layouts/BlogLayout.astro'
import { supabase } from '../../lib/supabase'
import type { Guide } from '../../types'

const SITE = 'https://blog.yayababy.app'

const { data } = await supabase
  .from('guides')
  .select('id, slug, title, subtitle, description, price_cents, cover_image_url, status, audience, target_week_start, target_week_end')
  .eq('status', 'published')
  .order('created_at', { ascending: true })

const guides = (data ?? []) as Guide[]

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Biblioteca Yaya — Guias para gestantes e pais',
  description: 'Guias práticos baseados em evidências para gestantes e pais. Acesse avulso ou com Yaya+.',
  url: `${SITE}/biblioteca-yaya`,
  numberOfItems: guides.length,
  itemListElement: guides.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE}/biblioteca-yaya/${g.slug}`,
    name: g.title,
  })),
}

function formatPrice(cents: number): string {
  return `R$ ${Math.floor(cents / 100)}`
}

function audienceLabel(g: Guide): string {
  if (g.audience === 'gestante') return '🤰 Gestação'
  if (g.audience === 'bebe') return '👶 0–12 meses'
  if (g.audience === 'bebe-24') return '👶 0–24 meses'
  const w = g.target_week_start ?? 0
  if (w <= 0) return '👶 Bebê'
  if (w <= 12) return '👶 0–3 meses'
  if (w <= 26) return '🌱 3–6 meses'
  return '🚼 6 meses +'
}
---

<BlogLayout
  title="Sua Biblioteca Yaya — Guias para gestantes e pais"
  description="Guias práticos sobre gestação, recém-nascido e primeiros meses do bebê. Conteúdo baseado em evidências, feito para quem cuida. Acesse avulso ou com o Yaya+."
  canonicalUrl={`${SITE}/biblioteca-yaya`}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListLd)} />

  <!-- Hero editorial premium -->
  <section class="max-w-4xl mx-auto px-4 pt-14 pb-10 text-center">

    <!-- Linha dourada decorativa -->
    <div class="flex items-center justify-center gap-3 mb-5">
      <div class="h-px w-12 bg-gradient-to-r from-transparent to-[#f5c842]/50"></div>
      <span class="text-[10px] font-display font-bold uppercase tracking-[0.2em]" style="color: #f5c842;">
        ✦ Biblioteca Yaya ✦
      </span>
      <div class="h-px w-12 bg-gradient-to-l from-transparent to-[#f5c842]/50"></div>
    </div>

    <h1
      class="font-display font-bold text-4xl md:text-5xl text-yaya-cloud leading-tight tracking-tight mb-4"
    >
      Guias que acompanham<br class="hidden md:block" />
      <span class="text-yaya-purple">cada etapa com você.</span>
    </h1>
    <p class="text-yaya-cloud/55 text-base font-sans max-w-xl mx-auto leading-relaxed mb-8">
      Conteúdo aprofundado, baseado em evidências — empacotado em guias práticos
      para quem está na gestação ou nos primeiros meses com o bebê.
    </p>

    <!-- Yaya+ badge -->
    <div
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-sans"
      style="background: rgba(245,200,66,0.08); border: 1px solid rgba(245,200,66,0.25); color: #f5c842;"
    >
      <span class="font-bold">Yaya+ Anual e Vitalício</span>
      <span style="color: rgba(245,200,66,0.7);">desbloqueia toda a biblioteca</span>
    </div>
  </section>

  <!-- Grid de guias -->
  <section class="max-w-4xl mx-auto px-4 pb-24">
    {guides.length === 0 && (
      <div class="text-center py-20">
        <img src="/symbol.png" alt="" class="h-12 w-auto mx-auto mb-5 opacity-30" />
        <p class="text-yaya-cloud/50 font-sans">Em breve novos guias por aqui.</p>
      </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {guides.map((guide) => {
        const price = formatPrice(guide.price_cents)
        const badge = audienceLabel(guide)
        return (
          /* Wrapper do gradiente dourado — cria a borda premium */
          <div
            class="guide-card-wrapper rounded-2xl p-px transition-all duration-300"
            style="background: linear-gradient(135deg, rgba(245,200,66,0.35) 0%, rgba(183,159,255,0.25) 50%, rgba(245,200,66,0.2) 100%);"
          >
            <a
              href={`/biblioteca-yaya/${guide.slug}`}
              class="group guide-card-inner flex flex-col rounded-2xl overflow-hidden bg-yaya-night transition-all duration-300 h-full"
            >
              <!-- Cover image -->
              <div class="relative aspect-[3/2] overflow-hidden" style="background: rgba(183,159,255,0.08);">
                {guide.cover_image_url
                  ? (
                    <img
                      src={guide.cover_image_url}
                      alt={guide.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  )
                  : (
                    <div class="w-full h-full flex items-center justify-center">
                      <img src="/symbol.png" alt="" class="h-14 w-auto opacity-20" />
                    </div>
                  )
                }
                <!-- Overlay gradiente -->
                <div class="absolute inset-0 bg-gradient-to-t from-yaya-night/80 via-transparent to-transparent" />

                <!-- Coroa premium (top-right) -->
                <div
                  class="absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-display font-bold backdrop-blur-sm"
                  style="background: rgba(13,10,39,0.75); border: 1px solid rgba(245,200,66,0.4); color: #f5c842;"
                >
                  👑 Premium
                </div>

                <!-- Badge de fase (bottom-left) -->
                <span class="absolute bottom-3 left-3 text-xs font-display font-bold px-2.5 py-1 rounded-full backdrop-blur-sm" style="background: rgba(13,10,39,0.7); color: rgba(231,226,255,0.8); border: 1px solid rgba(231,226,255,0.1);">
                  {badge}
                </span>
              </div>

              <!-- Conteúdo do card -->
              <div class="p-5 flex flex-col flex-1">
                <h2
                  class="font-display text-yaya-cloud font-bold text-lg leading-snug mb-1.5 line-clamp-2 transition-colors duration-200 group-hover:text-yaya-purple"
                >
                  {guide.title}
                </h2>
                <p class="text-yaya-cloud/50 text-sm font-sans leading-snug mb-4 line-clamp-2 flex-1">
                  {guide.subtitle ?? ''}
                </p>

                <!-- Rodapé: preço + CTA -->
                <div class="flex items-center justify-between pt-3 mt-auto" style="border-top: 1px solid rgba(245,200,66,0.1);">
                  <div>
                    <span class="font-display font-bold text-base" style="color: #f5c842;">{price}</span>
                    <span class="text-yaya-cloud/30 text-xs font-sans ml-1.5">ou Yaya+ Anual</span>
                  </div>
                  <span class="text-yaya-purple text-xs font-display font-bold transition-transform duration-200 group-hover:translate-x-0.5">
                    Ver detalhes →
                  </span>
                </div>
              </div>
            </a>
          </div>
        )
      })}
    </div>

    <!-- Bloco Yaya+ (abaixo do grid) -->
    {guides.length > 0 && (
      <div
        class="mt-14 rounded-2xl p-px"
        style="background: linear-gradient(135deg, rgba(245,200,66,0.2) 0%, rgba(183,159,255,0.2) 100%);"
      >
        <div class="rounded-2xl p-8 text-center lp-yayaplus-block" style="background: rgba(13,10,39,0.95); --yaya-cloud: var(--yaya-cloud-dark); --yaya-purple: var(--yaya-purple-dark);">
          <p
            class="font-display font-bold text-xs uppercase tracking-widest mb-3"
            style="color: #f5c842;"
          >
            ✦ Yaya+ Anual e Vitalício
          </p>
          <p class="text-yaya-cloud font-sans text-base mb-2">
            Assine o plano Anual ou Vitalício e acesse <strong>toda a biblioteca</strong> sem pagar por guia.
          </p>
          <p class="text-yaya-cloud/50 text-sm font-sans mb-6">
            O plano Mensal não inclui a biblioteca. Com Anual ou Vitalício, o app e todos os guias ficam juntos.
          </p>
          <a
            href="https://yayababy.app"
            class="inline-block font-display font-bold text-sm px-7 py-3 rounded-xl transition-colors"
            style="background: linear-gradient(135deg, #f5c842 0%, #f0a020 100%); color: #0d0a27;"
          >
            Conhecer o Yaya+
          </a>
          <p class="mt-4 text-yaya-cloud/30 text-xs font-sans">
            Já é assinante?{' '}
            <a href="/minha-biblioteca" class="hover:text-yaya-cloud transition-colors" style="color: rgba(245,200,66,0.6);">Entrar na biblioteca →</a>
          </p>
        </div>
      </div>
    )}
  </section>
</BlogLayout>

<style>
  /* Glow dourado no hover do card */
  .guide-card-wrapper:hover {
    box-shadow: 0 0 40px rgba(245, 200, 66, 0.12), 0 8px 32px rgba(0, 0, 0, 0.4);
    transform: translateY(-2px);
  }
  /* Intensifica borda dourada no hover */
  .guide-card-wrapper:hover {
    background: linear-gradient(135deg, rgba(245,200,66,0.6) 0%, rgba(183,159,255,0.4) 50%, rgba(245,200,66,0.4) 100%) !important;
  }
</style>
