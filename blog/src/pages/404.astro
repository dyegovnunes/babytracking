---
import BlogLayout from '../layouts/BlogLayout.astro'
---

<BlogLayout title="Página não encontrada | Yaya Baby">
  <div class="max-w-2xl mx-auto px-4 py-32 text-center">
    <p class="text-6xl mb-6">🐣</p>
    <h1 class="text-2xl font-bold text-white mb-3">Artigo não encontrado</h1>
    <p class="text-zinc-400 mb-8">Este artigo não existe ou foi removido.</p>
    <a
      href="/"
      class="inline-block bg-violet-600 hover:bg-violet-500 text-white font-bold px-5 py-2.5 rounded-lg transition-colors"
    >
      Ver todos os artigos
    </a>
  </div>
</BlogLayout>
