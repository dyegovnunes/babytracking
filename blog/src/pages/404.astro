---
import BlogLayout from '../layouts/BlogLayout.astro'
---

<BlogLayout title="Página não encontrada | Yaya Baby">
  <div class="max-w-xl mx-auto px-4 py-32 text-center">
    <img src="/symbol.png" alt="Yaya" class="h-16 w-auto mx-auto mb-6 opacity-50" />
    <h1 class="font-display text-2xl font-bold text-yaya-cloud mb-3 tracking-tight">Artigo não encontrado</h1>
    <p class="text-yaya-cloud/60 mb-8 font-sans leading-relaxed">
      Este guia não existe ou saiu do ar. Volte pra lista e explore o que tem por aí.
    </p>
    <a
      href="/"
      class="inline-block bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold px-5 py-2.5 rounded-md transition-colors"
    >
      Ver todos os guias
    </a>
  </div>
</BlogLayout>
