---
import BlogLayout from '../layouts/BlogLayout.astro'
import { supabase } from '../lib/supabase'
import type { BlogPost, ContentCategory } from '../types'
import { CATEGORY_LABEL, CATEGORY_EMOJI } from '../types'

const { data: posts, error } = await supabase
  .from('blog_posts')
  .select('id, slug, title, meta_description, category, target_week_start, target_week_end, image_url, published_at')
  .eq('status', 'published')
  .order('published_at', { ascending: false })

const allPosts = (posts ?? []) as BlogPost[]

const categories: ContentCategory[] = [
  'alimentacao', 'sono', 'desenvolvimento', 'saude', 'rotina', 'marcos',
]

function formatWeekRange(start: number | null, end: number | null): string {
  if (!start) return ''
  if (!end || start === end) return `Semana ${start}`
  return `Semanas ${start}–${end}`
}
---

<BlogLayout
  title="Blog Yaya Baby — Guias para pais de primeira viagem"
  description="Artigos práticos e baseados em evidências sobre alimentação, sono, desenvolvimento e saúde do bebê. Escritos para pais reais."
>
  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-4 pt-14 pb-10 text-center">
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
      Guias para acompanhar<br class="hidden md:block" /> o seu bebê
    </h1>
    <p class="text-zinc-400 text-lg max-w-xl mx-auto">
      Conteúdo prático, baseado em evidências, feito para pais de primeira viagem.
    </p>
  </section>

  <!-- Filtro por categoria -->
  <section class="max-w-3xl mx-auto px-4 mb-10">
    <div class="flex flex-wrap gap-2">
      <a
        href="/"
        class="px-3 py-1.5 rounded-full text-sm font-medium bg-violet-600 text-white"
      >
        Todos
      </a>
      {categories.map((cat) => (
        <a
          href={`/?categoria=${cat}`}
          class="px-3 py-1.5 rounded-full text-sm font-medium bg-zinc-800 text-zinc-300 hover:bg-zinc-700 transition-colors"
        >
          {CATEGORY_EMOJI[cat]} {CATEGORY_LABEL[cat]}
        </a>
      ))}
    </div>
  </section>

  <!-- Lista de artigos -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    {error && (
      <p class="text-zinc-500 text-center py-20">Erro ao carregar artigos. Tente novamente.</p>
    )}

    {!error && allPosts.length === 0 && (
      <p class="text-zinc-500 text-center py-20">Nenhum artigo publicado ainda.</p>
    )}

    <div class="space-y-6">
      {allPosts.map((post) => (
        <a
          href={`/${post.slug}`}
          class="group block bg-zinc-900 rounded-xl overflow-hidden border border-zinc-800 hover:border-violet-500/40 transition-colors"
        >
          <div class="flex gap-4 p-5">
            {post.image_url ? (
              <img
                src={post.image_url}
                alt={post.title}
                class="w-24 h-24 rounded-lg object-cover shrink-0"
                loading="lazy"
              />
            ) : (
              <div class="w-24 h-24 rounded-lg bg-zinc-800 flex items-center justify-center shrink-0">
                <span class="text-3xl">{CATEGORY_EMOJI[post.category as ContentCategory]}</span>
              </div>
            )}

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-semibold text-violet-400 uppercase tracking-wide">
                  {CATEGORY_LABEL[post.category as ContentCategory]}
                </span>
                {post.target_week_start && (
                  <span class="text-xs text-zinc-600">
                    · {formatWeekRange(post.target_week_start, post.target_week_end)}
                  </span>
                )}
              </div>

              <h2 class="font-bold text-white text-base leading-snug mb-2 group-hover:text-violet-300 transition-colors">
                {post.title}
              </h2>

              {post.meta_description && (
                <p class="text-zinc-400 text-sm line-clamp-2 leading-relaxed">
                  {post.meta_description}
                </p>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BlogLayout>
