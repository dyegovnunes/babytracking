---
import BlogLayout from '../layouts/BlogLayout.astro'
import { supabase } from '../lib/supabase'
import type { BlogPost } from '../types'
import CategorySidebar from '../components/CategorySidebar.astro'
import FilterToolbar from '../components/FilterToolbar.astro'
import PostCard from '../components/PostCard.astro'
import HeroFeatured from '../components/HeroFeatured.astro'

const { data: postsData, error } = await supabase
  .from('blog_posts')
  .select('id, slug, title, meta_description, content_md, keywords, category, audience, pillar, role, related_slugs, schema_type, affiliate_products, premium_teaser, target_week_start, target_week_end, image_url, image_alt, published_at, post_number')
  .eq('status', 'published')
  .order('published_at', { ascending: false })

const allPosts = (postsData ?? []) as BlogPost[]

// Agrega stats de feedback pra ordering client-side
const { data: feedbackData } = await supabase
  .from('content_feedback')
  .select('post_slug, sentiment')

const feedbackStats: Record<string, { total: number; helpful: number; approval: number }> = {}
for (const row of feedbackData ?? []) {
  const s = row.post_slug as string
  if (!feedbackStats[s]) feedbackStats[s] = { total: 0, helpful: 0, approval: 0 }
  feedbackStats[s].total++
  if (row.sentiment === 'helpful') feedbackStats[s].helpful++
}
for (const s in feedbackStats) {
  feedbackStats[s].approval =
    feedbackStats[s].total > 0 ? feedbackStats[s].helpful / feedbackStats[s].total : 0
}

// Counts por categoria (pra sidebar) e por fase (pra chips)
const countsByCategory: Record<string, number> = {}
const countsByPhase: Record<string, number> = {}
function phaseOf(p: BlogPost): string {
  if (p.audience === 'gestante') return 'gestante'
  const w = p.target_week_start ?? 0
  if (w <= 12) return '0-3m'
  if (w <= 26) return '3-6m'
  return '6m+'
}
for (const p of allPosts) {
  countsByCategory[p.category] = (countsByCategory[p.category] ?? 0) + 1
  const ph = phaseOf(p)
  countsByPhase[ph] = (countsByPhase[ph] ?? 0) + 1
}

// Featured posts no hero — 3 posts priorizando COM imagem, ordenados por views
// (views usa count de content_feedback como proxy enquanto GA4 não integra).
// Fallback: se não tiver posts com imagem suficientes, completa com posts
// mais recentes sem imagem.
const postsWithImage = allPosts.filter((p) => p.image_url)
const postsWithoutImage = allPosts.filter((p) => !p.image_url)

function viewsOf(slug: string): number {
  return feedbackStats[slug]?.total ?? 0
}
const sortedByViews = [...postsWithImage].sort((a, b) => {
  const diff = viewsOf(b.slug) - viewsOf(a.slug)
  if (diff !== 0) return diff
  return (b.published_at ?? '').localeCompare(a.published_at ?? '')
})
const featuredPosts = [
  ...sortedByViews.slice(0, 3),
  ...postsWithoutImage.slice(0, Math.max(0, 3 - sortedByViews.length)),
].slice(0, 3)
---

<BlogLayout
  title="Blog Yaya Baby — Rotina do seu bebê, com calma"
  description="Guias sobre sono, alimentação, desenvolvimento e saúde do bebê. Baseados em evidências, escritos para pais reais."
>
  <!-- Hero compacto -->
  <section class="max-w-5xl mx-auto px-4 pt-12 pb-8 text-center">
    <h1 class="font-display text-4xl md:text-5xl font-extrabold text-yaya-cloud leading-tight tracking-tight">
      A rotina do seu bebê,<br class="hidden md:block" />
      <span class="text-yaya-purple">explicada com calma.</span>
    </h1>
  </section>

  <!-- Posts em destaque (3 posts, priorizando com imagem + mais vistos) -->
  <HeroFeatured posts={featuredPosts} />

  <div class="max-w-5xl mx-auto px-4 pb-20 md:flex md:gap-10 md:items-start">

    <CategorySidebar counts={countsByCategory} phaseCounts={countsByPhase} />

    <!-- Main: toolbar + grid de posts -->
    <main class="flex-1 min-w-0">
      <FilterToolbar />

      {error && (
        <p class="text-yaya-cloud/50 text-center py-20 font-sans">
          Não conseguimos carregar os artigos agora. Tenta de novo em alguns instantes.
        </p>
      )}

      {!error && allPosts.length === 0 && (
        <div class="text-center py-20">
          <img src="/symbol.png" alt="" class="h-12 w-auto mx-auto mb-5 opacity-40" />
          <p class="text-yaya-cloud/60 font-sans">Ainda estamos preparando os primeiros guias.</p>
        </div>
      )}

      <div id="posts-root" data-view="grid">
        {allPosts.map((post) => {
          const stats = feedbackStats[post.slug] ?? { total: 0, helpful: 0, approval: 0 }
          return (
            <PostCard
              post={post}
              viewsCount={stats.total}
              feedbackTotal={stats.total}
              feedbackApproval={stats.approval}
            />
          )
        })}
      </div>
    </main>
  </div>
</BlogLayout>

<script>
  import '../scripts/blogFilters'
</script>
