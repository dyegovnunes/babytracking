---
import type { BlogPost, ContentCategory } from '../types'
import { CATEGORY_LABEL, CATEGORY_EMOJI } from '../types'

interface Props {
  post: BlogPost
}

const { post } = Astro.props
---

<section class="max-w-3xl mx-auto px-4 mb-14">
  <p class="text-[10px] font-display font-bold text-yaya-purple uppercase tracking-wider mb-3 flex items-center gap-1.5">
    <span>✨</span> Em destaque
  </p>
  <a
    href={`/${post.slug}`}
    class="group block rounded-md overflow-hidden bg-gradient-to-br from-yaya-purple/15 to-yaya-blush/10 border border-yaya-purple/25 hover:border-yaya-purple/50 transition-all"
  >
    <div class="flex flex-col md:flex-row gap-0">
      {post.image_url ? (
        <img
          src={post.image_url}
          alt={post.image_alt ?? post.title}
          class="w-full md:w-64 h-52 md:h-auto object-cover md:self-stretch"
        />
      ) : (
        <div class="w-full md:w-64 h-52 md:h-auto bg-yaya-purple/10 flex items-center justify-center md:self-stretch">
          <span class="text-6xl">{CATEGORY_EMOJI[post.category as ContentCategory]}</span>
        </div>
      )}

      <div class="flex-1 p-6 md:p-7">
        <span class="text-[10px] font-display font-bold text-yaya-purple uppercase tracking-wider">
          {CATEGORY_LABEL[post.category as ContentCategory]}
        </span>
        <h3 class="font-display text-xl md:text-2xl font-extrabold text-yaya-cloud leading-tight mt-2 mb-3 group-hover:text-yaya-purple transition-colors tracking-tight">
          {post.title}
        </h3>
        {post.meta_description && (
          <p class="text-yaya-cloud/70 text-sm leading-relaxed font-sans line-clamp-3">
            {post.meta_description}
          </p>
        )}
        <span class="inline-block mt-4 text-yaya-purple font-display font-bold text-sm">
          Ler guia →
        </span>
      </div>
    </div>
  </a>
</section>
