---
// Botão de toggle de tema. Persiste escolha em localStorage ('yb_theme').
// CSS cuida de qual ícone mostrar (ver theme.css). JS aplica classe no <html>
// e atualiza meta theme-color pra reagir na barra do Android.
---

<button
  type="button"
  id="theme-toggle"
  class="w-9 h-9 rounded-full bg-yaya-cloud/10 hover:bg-yaya-cloud/15 flex items-center justify-center text-yaya-cloud transition-colors"
  aria-label="Alternar tema claro/escuro"
>
  <!-- Sol (mostrado em dark mode; clicar → light) -->
  <svg
    class="theme-toggle-sun"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>

  <!-- Lua (mostrada em light mode; clicar → dark) -->
  <svg
    class="theme-toggle-moon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle')
  const KEY = 'yb_theme'
  const html = document.documentElement

  function currentMode(): 'light' | 'dark' {
    if (html.classList.contains('theme-light')) return 'light'
    if (html.classList.contains('theme-dark')) return 'dark'
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'
  }

  function updateMetaThemeColor(mode: 'light' | 'dark') {
    // Meta tags já têm media queries, mas o override manual não propaga pra media query.
    // Solução: atualizamos via JS quando houver override explícito.
    const tags = document.querySelectorAll<HTMLMetaElement>('meta[name="theme-color"]')
    tags.forEach((t) => t.remove())
    const m = document.createElement('meta')
    m.name = 'theme-color'
    m.content = mode === 'light' ? '#fafafe' : '#0d0a27'
    document.head.appendChild(m)
  }

  btn?.addEventListener('click', () => {
    const next = currentMode() === 'dark' ? 'light' : 'dark'
    html.classList.remove('theme-light', 'theme-dark')
    html.classList.add(`theme-${next}`)
    try { localStorage.setItem(KEY, next) } catch {}
    updateMetaThemeColor(next)
  })
</script>
