---
import { CATEGORY_LABEL, CATEGORY_EMOJI } from '../types'
import type { ContentCategory } from '../types'

interface Props {
  counts: Record<string, number>
  phaseCounts: Record<string, number>
  activeCategory?: ContentCategory | null
}

const { counts, phaseCounts, activeCategory = null } = Astro.props

// Ordem visual — agrupado por fase do bebê
const categories: ContentCategory[] = [
  'gestacao', 'alimentacao', 'amamentacao',
  'sono', 'rotina', 'saude',
  'seguranca', 'desenvolvimento', 'marcos',
]

const phases = [
  { id: 'all',      emoji: '📚', label: 'Todos' },
  { id: 'gestante', emoji: '🤰', label: 'Gestante' },
  { id: '0-3m',     emoji: '👶', label: '0–3 meses' },
  { id: '3-6m',     emoji: '🌱', label: '3–6 meses' },
  { id: '6m+',      emoji: '🚼', label: '6 meses +' },
] as const
---

<!-- DESKTOP: sidebar sticky -->
<aside class="hidden md:block w-52 shrink-0">
  <nav class="sticky top-20" aria-label="Filtros">

    <!-- Seção: Fase -->
    <p class="font-display text-[10px] font-bold uppercase tracking-wider text-yaya-cloud/50 mb-2 px-2">
      Fase
    </p>
    <div class="flex flex-wrap gap-1.5 px-1 mb-5">
      {phases.map((p) => (
        <button
          type="button"
          class="phase-chip shrink-0 flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-display font-bold bg-yaya-cloud/5 text-yaya-cloud/70 hover:bg-yaya-cloud/10 hover:text-yaya-cloud transition-colors data-[active=true]:bg-yaya-purple/20 data-[active=true]:text-yaya-purple"
          data-phase={p.id}
          data-active={p.id === 'all' ? 'true' : 'false'}
        >
          <span>{p.emoji}</span>
          <span>{p.label}</span>
          {p.id !== 'all' && phaseCounts[p.id] !== undefined && (
            <span class="opacity-50 tabular-nums">{phaseCounts[p.id]}</span>
          )}
        </button>
      ))}
    </div>

    <!-- Divider -->
    <div class="border-t border-yaya-cloud/8 mb-4 mx-1"></div>

    <!-- Seção: Categorias -->
    <p class="font-display text-[10px] font-bold uppercase tracking-wider text-yaya-cloud/50 mb-2 px-2">
      Categorias
    </p>
    <ul class="space-y-0.5">
      <li>
        <a
          href="/"
          class:list={[
            'flex items-center gap-2.5 px-2.5 py-2 rounded-md text-sm font-sans font-medium transition-colors',
            activeCategory === null
              ? 'bg-yaya-purple/15 text-yaya-purple'
              : 'text-yaya-cloud/70 hover:bg-yaya-cloud/5 hover:text-yaya-cloud',
          ]}
        >
          <span class="text-base">📚</span>
          <span class="flex-1">Todos</span>
        </a>
      </li>
      {categories.map((cat) => {
        const n = counts[cat] ?? 0
        const active = cat === activeCategory
        return (
          <li>
            <a
              href={`/categoria/${cat}`}
              class:list={[
                'flex items-center gap-2.5 px-2.5 py-2 rounded-md text-sm font-sans font-medium transition-colors',
                active
                  ? 'bg-yaya-purple/15 text-yaya-purple'
                  : 'text-yaya-cloud/70 hover:bg-yaya-cloud/5 hover:text-yaya-cloud',
              ]}
            >
              <span class="text-base">{CATEGORY_EMOJI[cat]}</span>
              <span class="flex-1">{CATEGORY_LABEL[cat]}</span>
              <span class:list={[
                'text-[10px] tabular-nums',
                active ? 'text-yaya-purple/70' : 'text-yaya-cloud/40',
              ]}>
                {n}
              </span>
            </a>
          </li>
        )
      })}
    </ul>
  </nav>
</aside>

<!-- MOBILE: chips horizontais scrolláveis (fases + separador + categorias) -->
<nav class="md:hidden mb-6 -mx-4" aria-label="Filtros">
  <div class="flex gap-2 overflow-x-auto px-4 pb-1 scrollbar-hide">
    <!-- Fases -->
    {phases.map((p) => (
      <button
        type="button"
        class="phase-chip shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-display font-bold bg-yaya-cloud/5 text-yaya-cloud/80 hover:bg-yaya-cloud/10 transition-colors data-[active=true]:bg-yaya-purple data-[active=true]:text-yaya-night"
        data-phase={p.id}
        data-active={p.id === 'all' ? 'true' : 'false'}
      >
        <span>{p.emoji}</span>
        <span>{p.label}</span>
      </button>
    ))}

    <!-- Separador visual entre fases e categorias -->
    <span aria-hidden="true" class="shrink-0 self-center w-px h-5 bg-yaya-cloud/15 mx-1"></span>

    <!-- Categorias -->
    {categories.map((cat) => {
      const active = cat === activeCategory
      return (
        <a
          href={`/categoria/${cat}`}
          class:list={[
            'shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-display font-bold transition-colors',
            active
              ? 'bg-yaya-purple text-yaya-night'
              : 'bg-yaya-cloud/5 text-yaya-cloud/80 hover:bg-yaya-cloud/10',
          ]}
        >
          <span>{CATEGORY_EMOJI[cat]}</span>
          <span>{CATEGORY_LABEL[cat]}</span>
        </a>
      )
    })}
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
