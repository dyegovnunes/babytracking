---
import { CATEGORY_LABEL, CATEGORY_EMOJI } from '../types'
import type { ContentCategory } from '../types'

interface Props {
  counts: Record<string, number>
  activeCategory?: ContentCategory | null
}

const { counts, activeCategory = null } = Astro.props

// Ordem visual — agrupado por fase do bebê
const categories: ContentCategory[] = [
  'gestacao', 'alimentacao', 'amamentacao',
  'sono', 'rotina', 'saude',
  'seguranca', 'desenvolvimento', 'marcos',
]
---

<!-- DESKTOP: sidebar sticky -->
<aside class="hidden md:block w-52 shrink-0">
  <nav
    class="sticky top-20"
    aria-label="Categorias"
  >
    <p class="font-display text-[10px] font-bold uppercase tracking-wider text-yaya-cloud/50 mb-3 px-2">
      Categorias
    </p>
    <ul class="space-y-0.5">
      <li>
        <a
          href="/"
          class:list={[
            'flex items-center gap-2.5 px-2.5 py-2 rounded-md text-sm font-sans font-medium transition-colors',
            activeCategory === null
              ? 'bg-yaya-purple/15 text-yaya-purple'
              : 'text-yaya-cloud/70 hover:bg-yaya-cloud/5 hover:text-yaya-cloud',
          ]}
        >
          <span class="text-base">📚</span>
          <span class="flex-1">Todos</span>
        </a>
      </li>
      {categories.map((cat) => {
        const n = counts[cat] ?? 0
        const active = cat === activeCategory
        return (
          <li>
            <a
              href={`/categoria/${cat}`}
              class:list={[
                'flex items-center gap-2.5 px-2.5 py-2 rounded-md text-sm font-sans font-medium transition-colors',
                active
                  ? 'bg-yaya-purple/15 text-yaya-purple'
                  : 'text-yaya-cloud/70 hover:bg-yaya-cloud/5 hover:text-yaya-cloud',
              ]}
            >
              <span class="text-base">{CATEGORY_EMOJI[cat]}</span>
              <span class="flex-1">{CATEGORY_LABEL[cat]}</span>
              <span class:list={[
                'text-[10px] tabular-nums',
                active ? 'text-yaya-purple/70' : 'text-yaya-cloud/40',
              ]}>
                {n}
              </span>
            </a>
          </li>
        )
      })}
    </ul>
  </nav>
</aside>

<!-- MOBILE: chips horizontais scrolláveis -->
<nav
  class="md:hidden mb-6 -mx-4"
  aria-label="Categorias"
>
  <div class="flex gap-2 overflow-x-auto px-4 pb-1 scrollbar-hide">
    <a
      href="/"
      class:list={[
        'shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-display font-bold transition-colors',
        activeCategory === null
          ? 'bg-yaya-purple text-yaya-night'
          : 'bg-yaya-cloud/5 text-yaya-cloud/80 hover:bg-yaya-cloud/10',
      ]}
    >
      <span>📚</span>
      <span>Todos</span>
    </a>
    {categories.map((cat) => {
      const active = cat === activeCategory
      return (
        <a
          href={`/categoria/${cat}`}
          class:list={[
            'shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-display font-bold transition-colors',
            active
              ? 'bg-yaya-purple text-yaya-night'
              : 'bg-yaya-cloud/5 text-yaya-cloud/80 hover:bg-yaya-cloud/10',
          ]}
        >
          <span>{CATEGORY_EMOJI[cat]}</span>
          <span>{CATEGORY_LABEL[cat]}</span>
        </a>
      )
    })}
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
