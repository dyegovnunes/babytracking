---
import type { AffiliateProduct } from '../types'

interface Props {
  products: AffiliateProduct[]
}

const { products } = Astro.props

if (!products || products.length === 0) {
  return
}
---

<section class="mt-12 mb-2">
  <div class="flex items-center gap-3 mb-1">
    <h2 class="font-display text-lg font-bold text-yaya-cloud">Produtos que podem ajudar</h2>
  </div>
  <p class="text-xs text-yaya-cloud/40 font-sans mb-5">
    Produtos da Amazon selecionados para você — compre e apoie o Yaya Blog ♥
  </p>

  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    {products.map((p) => (
      <a
        href={p.url}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="group flex flex-col rounded-md border border-yaya-cloud/10 bg-yaya-cloud/[0.03] hover:border-yaya-purple/40 hover:bg-yaya-purple/5 transition-colors overflow-hidden"
        data-asin={p.asin}
        data-nome={p.nome}
        data-tipo={p.tipo}
      >
        <div class="relative bg-white flex items-center justify-center p-2 h-28 overflow-hidden">
          <!-- Placeholder: visível quando a imagem falha ou é bloqueada pelo CDN -->
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-1 pointer-events-none">
            <svg class="w-8 h-8 text-gray-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.5"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
            <span class="text-[9px] text-gray-300 font-sans tracking-wide uppercase">Amazon</span>
          </div>
          <!-- Imagem do produto (z-10 fica sobre o placeholder) -->
          <img
            src={`https://m.media-amazon.com/images/P/${p.asin}.01._SX500_QL70_.jpg`}
            alt={p.nome}
            class="relative z-10 max-h-24 max-w-full object-contain"
            loading="lazy"
            onerror="this.remove()"
            onload="if(this.naturalWidth<=1)this.remove()"
          />
        </div>
        <div class="p-3 flex flex-col gap-1 flex-1">
          <span class="text-[10px] font-bold uppercase tracking-wider text-yaya-purple/70 font-sans">
            {p.tipo}
          </span>
          <span class="text-xs text-yaya-cloud/80 font-sans leading-snug line-clamp-3">
            {p.nome}
          </span>
          <span class="mt-auto pt-2 text-xs font-display font-bold text-yaya-purple group-hover:text-yaya-glow transition-colors">
            Ver na Amazon →
          </span>
        </div>
      </a>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-asin]').forEach((link) => {
    link.addEventListener('click', () => {
      if (typeof gtag !== 'function') return
      gtag('event', 'affiliate_click', {
        affiliate_asin: link.dataset.asin ?? '',
        affiliate_product: link.dataset.nome ?? '',
        affiliate_tipo: link.dataset.tipo ?? '',
        article_slug: window.location.pathname,
      })
    })
  })
</script>
