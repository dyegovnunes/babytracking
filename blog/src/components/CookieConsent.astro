---
// Banner LGPD granular com 3 categorias (essenciais, analytics, marketing)
// Por enquanto expomos só essenciais + analytics. Marketing fica pronto pro futuro.
---

<!-- Banner fixo no bottom da viewport — visível até usuário escolher -->
<div
  id="yb-cookie-banner"
  class="fixed inset-x-0 bottom-0 z-[100] hidden bg-yaya-night/95 backdrop-blur-sm border-t border-yaya-cloud/15"
  role="dialog"
  aria-labelledby="yb-cookie-banner-title"
>
  <div class="max-w-4xl mx-auto px-4 py-5 md:py-6 flex flex-col md:flex-row gap-5 md:items-center">
    <div class="flex-1">
      <p id="yb-cookie-banner-title" class="font-display font-bold text-yaya-cloud text-sm mb-1">
        Seus dados, suas regras
      </p>
      <p class="font-sans text-xs text-yaya-cloud/70 leading-relaxed">
        Usamos cookies essenciais pra o blog funcionar e, se você permitir, de análise pra entender como melhorar.
        <a href="https://yayababy.app/privacidade" class="text-yaya-purple hover:text-yaya-glow underline" target="_blank" rel="noopener">Saiba mais</a>.
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <button
        type="button"
        id="yb-cookie-essentials-only"
        class="px-4 py-2 rounded-md bg-yaya-cloud/5 hover:bg-yaya-cloud/10 border border-yaya-cloud/10 text-yaya-cloud/80 hover:text-yaya-cloud font-sans font-medium text-xs transition-all"
      >
        Só essenciais
      </button>
      <button
        type="button"
        id="yb-cookie-customize"
        class="px-4 py-2 rounded-md bg-yaya-cloud/5 hover:bg-yaya-cloud/10 border border-yaya-cloud/10 text-yaya-cloud/80 hover:text-yaya-cloud font-sans font-medium text-xs transition-all"
      >
        Personalizar
      </button>
      <button
        type="button"
        id="yb-cookie-accept-all"
        class="px-4 py-2 rounded-md bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold text-xs transition-all"
      >
        Aceitar todos
      </button>
    </div>
  </div>
</div>

<!-- Modal de personalização -->
<div
  id="yb-cookie-modal"
  class="fixed inset-0 z-[110] hidden items-center justify-center bg-black/60 backdrop-blur-sm p-4"
  role="dialog"
  aria-labelledby="yb-cookie-modal-title"
  aria-modal="true"
>
  <div class="w-full max-w-md rounded-md bg-yaya-night border border-yaya-cloud/15 p-6 max-h-[85vh] overflow-y-auto">
    <div class="flex items-start justify-between mb-5">
      <div>
        <h2 id="yb-cookie-modal-title" class="font-display text-lg font-bold text-yaya-cloud tracking-tight">
          Preferências de cookies
        </h2>
        <p class="font-sans text-xs text-yaya-cloud/60 mt-1">
          Escolha quais categorias quer permitir.
        </p>
      </div>
      <button
        type="button"
        id="yb-cookie-modal-close"
        class="w-8 h-8 rounded-full bg-yaya-cloud/5 hover:bg-yaya-cloud/10 text-yaya-cloud/60 hover:text-yaya-cloud flex items-center justify-center transition-colors"
        aria-label="Fechar"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Categoria: Essenciais (sempre ligado) -->
    <div class="py-4 border-b border-yaya-cloud/10">
      <div class="flex items-start justify-between gap-3">
        <div class="flex-1">
          <p class="font-display font-bold text-yaya-cloud text-sm">Essenciais</p>
          <p class="font-sans text-xs text-yaya-cloud/60 mt-1 leading-relaxed">
            Necessários pro blog funcionar (preferência de cookies, voto do feedback).
            Não podem ser desativados.
          </p>
        </div>
        <div class="relative shrink-0 pt-0.5">
          <label class="flex items-center cursor-not-allowed opacity-50">
            <input type="checkbox" checked disabled class="sr-only peer" />
            <div class="w-10 h-6 bg-yaya-purple rounded-full flex items-center">
              <div class="w-4 h-4 bg-white rounded-full ml-auto mr-1"></div>
            </div>
          </label>
        </div>
      </div>
    </div>

    <!-- Categoria: Analytics (toggle) -->
    <div class="py-4 border-b border-yaya-cloud/10">
      <div class="flex items-start justify-between gap-3">
        <div class="flex-1">
          <p class="font-display font-bold text-yaya-cloud text-sm">Análise (Google Analytics)</p>
          <p class="font-sans text-xs text-yaya-cloud/60 mt-1 leading-relaxed">
            Nos ajuda a entender quais guias mais ajudam e onde podemos melhorar.
            Dados agregados, sem rastreamento pessoal.
          </p>
        </div>
        <button
          type="button"
          id="yb-cookie-toggle-analytics"
          role="switch"
          aria-checked="false"
          aria-label="Permitir cookies de análise"
          class="relative shrink-0 pt-0.5"
        >
          <div class="w-10 h-6 bg-yaya-cloud/15 rounded-full flex items-center transition-colors data-[on=true]:bg-yaya-purple" data-track>
            <div class="w-4 h-4 bg-white rounded-full transition-all ml-1 data-[on=true]:ml-auto data-[on=true]:mr-1" data-thumb></div>
          </div>
        </button>
      </div>
    </div>

    <div class="flex gap-2 mt-6">
      <button
        type="button"
        id="yb-cookie-modal-save"
        class="flex-1 px-4 py-2.5 rounded-md bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold text-sm transition-all"
      >
        Salvar preferências
      </button>
    </div>
  </div>
</div>

<script>
  type Consent = {
    version: 1
    essentials: true
    analytics: boolean
    set_at: string
  }

  const KEY = 'yb_consent_v1'

  function readConsent(): Consent | null {
    try {
      const raw = localStorage.getItem(KEY)
      if (!raw) return null
      const parsed = JSON.parse(raw)
      if (parsed?.version === 1) return parsed
    } catch {}
    return null
  }

  function saveConsent(analytics: boolean): Consent {
    const c: Consent = {
      version: 1,
      essentials: true,
      analytics,
      set_at: new Date().toISOString(),
    }
    try {
      localStorage.setItem(KEY, JSON.stringify(c))
    } catch {}
    // Sincroniza com Google Consent Mode v2
    const w = window as any
    if (typeof w.gtag === 'function') {
      w.gtag('consent', 'update', {
        analytics_storage: analytics ? 'granted' : 'denied',
      })
    }
    window.dispatchEvent(new CustomEvent('yb-consent-change', { detail: c }))
    return c
  }

  const banner = document.getElementById('yb-cookie-banner')
  const modal = document.getElementById('yb-cookie-modal')
  const toggle = document.getElementById('yb-cookie-toggle-analytics')
  const track = toggle?.querySelector<HTMLElement>('[data-track]')
  const thumb = toggle?.querySelector<HTMLElement>('[data-thumb]')

  let analyticsDraft = false  // estado temporário do modal

  function showBanner() {
    banner?.classList.remove('hidden')
  }
  function hideBanner() {
    banner?.classList.add('hidden')
  }
  function openModal() {
    const current = readConsent()
    analyticsDraft = current?.analytics ?? false
    renderToggle()
    modal?.classList.remove('hidden')
    modal?.classList.add('flex')
  }
  function closeModal() {
    modal?.classList.add('hidden')
    modal?.classList.remove('flex')
  }
  function renderToggle() {
    toggle?.setAttribute('aria-checked', String(analyticsDraft))
    track?.setAttribute('data-on', String(analyticsDraft))
    thumb?.setAttribute('data-on', String(analyticsDraft))
    if (track) {
      track.style.backgroundColor = analyticsDraft ? '#b79fff' : ''
    }
    if (thumb) {
      thumb.style.marginLeft = analyticsDraft ? 'auto' : '0.25rem'
      thumb.style.marginRight = analyticsDraft ? '0.25rem' : '0'
    }
  }

  // Estado inicial: mostra banner se ainda não consentiu
  if (!readConsent()) {
    showBanner()
  }

  // Botões do banner
  document.getElementById('yb-cookie-accept-all')?.addEventListener('click', () => {
    saveConsent(true)
    hideBanner()
  })
  document.getElementById('yb-cookie-essentials-only')?.addEventListener('click', () => {
    saveConsent(false)
    hideBanner()
  })
  document.getElementById('yb-cookie-customize')?.addEventListener('click', () => {
    openModal()
  })

  // Modal
  document.getElementById('yb-cookie-modal-close')?.addEventListener('click', closeModal)
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()
  })
  toggle?.addEventListener('click', () => {
    analyticsDraft = !analyticsDraft
    renderToggle()
  })
  document.getElementById('yb-cookie-modal-save')?.addEventListener('click', () => {
    saveConsent(analyticsDraft)
    closeModal()
    hideBanner()
  })

  // Expõe globalmente para reabrir via "Preferências de cookies" no footer
  ;(window as any).ybOpenCookiePrefs = openModal
</script>
