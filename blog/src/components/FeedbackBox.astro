---
interface Props {
  slug: string
  title: string
  url: string
  audience: 'gestante' | 'parent' | 'both'
  relatedSlugs: string[]
}

const { slug, title, url, audience, relatedSlugs } = Astro.props

// Texto do WhatsApp (reutilizado pra quando usuário clica 👍 — incentivo a compartilhar)
const waText = audience === 'gestante'
  ? `Achei esse guia sobre "${title}" e lembrei de você. Deixo aqui pra ler com calma 💜\n${url}`
  : `Achei esse guia do Yaya Baby sobre "${title}". Talvez te ajude 💜\n${url}`
const waUrl = `https://wa.me/?text=${encodeURIComponent(waText)}`
---

<section
  class="mt-12 pt-10 border-t border-yaya-cloud/10"
  data-feedback-slug={slug}
  data-feedback-wa={waUrl}
  id="feedback-box"
>
  <!-- Estado inicial: pergunta CSAT -->
  <div id="feedback-initial" class="text-center">
    <p class="font-display text-lg font-bold text-yaya-cloud mb-4">Esse guia ajudou?</p>
    <div class="flex items-center justify-center gap-3">
      <button
        type="button"
        data-vote="helpful"
        class="feedback-btn flex items-center gap-2 px-5 py-3 rounded-md bg-yaya-cloud/5 hover:bg-green-500/10 border border-yaya-cloud/10 hover:border-green-500/40 transition-all font-sans font-medium text-yaya-cloud/90"
        aria-label="Sim, ajudou"
      >
        <span class="text-xl">👍</span>
        <span>Sim, ajudou</span>
      </button>
      <button
        type="button"
        data-vote="not_helpful"
        class="feedback-btn flex items-center gap-2 px-5 py-3 rounded-md bg-yaya-cloud/5 hover:bg-yellow-500/10 border border-yaya-cloud/10 hover:border-yellow-500/40 transition-all font-sans font-medium text-yaya-cloud/90"
        aria-label="Não ajudou"
      >
        <span class="text-xl">👎</span>
        <span>Podia ser melhor</span>
      </button>
    </div>
  </div>

  <!-- Após 👍: incentivo a compartilhar -->
  <div id="feedback-helpful" class="hidden text-center p-5 rounded-md bg-green-500/5 border border-green-500/20">
    <p class="font-display text-base font-bold text-yaya-cloud mb-2">Que bom que ajudou 💜</p>
    <p class="text-sm text-yaya-cloud/70 font-sans mb-4">
      Manda pra quem também pode precisar:
    </p>
    <a
      id="feedback-wa-share"
      href={waUrl}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold px-5 py-2.5 rounded-md transition-colors text-sm"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      Compartilhar no WhatsApp
    </a>
  </div>

  <!-- Após 👎: mini form opcional -->
  <div id="feedback-not-helpful" class="hidden p-5 rounded-md bg-yellow-500/5 border border-yellow-500/20">
    <p class="font-display text-base font-bold text-yaya-cloud mb-2">Obrigado pelo retorno.</p>
    <p class="text-sm text-yaya-cloud/70 font-sans mb-3">
      O que faltou? Seu comentário ajuda a gente a melhorar o conteúdo (opcional).
    </p>
    <textarea
      id="feedback-comment"
      rows="3"
      maxlength="500"
      placeholder="Ex: faltou cobrir amamentação cruzada, links quebrados na seção X..."
      class="w-full px-3 py-2 rounded-md bg-yaya-night/50 border border-yaya-cloud/10 text-yaya-cloud text-sm font-sans placeholder:text-yaya-cloud/30 focus:border-yaya-purple/40 focus:outline-none resize-none"
    ></textarea>
    <div class="flex gap-2 mt-3">
      <button
        type="button"
        id="feedback-submit-comment"
        class="bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold px-4 py-2 rounded-md transition-colors text-sm"
      >
        Enviar
      </button>
      <button
        type="button"
        id="feedback-skip-comment"
        class="text-yaya-cloud/60 hover:text-yaya-cloud font-sans text-sm px-3 py-2"
      >
        Pular
      </button>
    </div>
  </div>

  <!-- Estado final: agradecimento -->
  <div id="feedback-thanks" class="hidden text-center text-yaya-cloud/70 font-sans text-sm py-2">
    Feedback recebido 💜
  </div>
</section>

<script>
  import { createClient } from '@supabase/supabase-js'

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  )

  const box = document.getElementById('feedback-box')
  if (box) {
    const slug = box.dataset.feedbackSlug as string
    const initial = document.getElementById('feedback-initial')
    const helpful = document.getElementById('feedback-helpful')
    const notHelpful = document.getElementById('feedback-not-helpful')
    const thanks = document.getElementById('feedback-thanks')
    const commentField = document.getElementById('feedback-comment') as HTMLTextAreaElement | null
    const submitComment = document.getElementById('feedback-submit-comment')
    const skipComment = document.getElementById('feedback-skip-comment')

    // Session ID anon persistido em localStorage
    function getSessionId(): string {
      let id = localStorage.getItem('yb_session_id')
      if (!id) {
        id = crypto.randomUUID()
        localStorage.setItem('yb_session_id', id)
      }
      return id
    }

    // Se já votou neste artigo, pula direto pro thanks
    const votedKey = `yb_feedback_voted_${slug}`
    if (localStorage.getItem(votedKey)) {
      initial?.classList.add('hidden')
      thanks?.classList.remove('hidden')
    }

    const buttons = document.querySelectorAll<HTMLButtonElement>('.feedback-btn')
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const sentiment = btn.dataset.vote as 'helpful' | 'not_helpful'
        const sessionId = getSessionId()

        // UPSERT (unique em post_slug+session_id)
        await supabase.from('content_feedback').upsert(
          {
            post_slug: slug,
            session_id: sessionId,
            sentiment,
            user_agent: navigator.userAgent.slice(0, 255),
          },
          { onConflict: 'post_slug,session_id' },
        )

        localStorage.setItem(votedKey, sentiment)

        initial?.classList.add('hidden')
        if (sentiment === 'helpful') {
          helpful?.classList.remove('hidden')
        } else {
          notHelpful?.classList.remove('hidden')
          commentField?.focus()
        }
      })
    })

    submitComment?.addEventListener('click', async () => {
      const comment = commentField?.value.trim() ?? ''
      if (comment.length > 0) {
        const sessionId = getSessionId()
        await supabase
          .from('content_feedback')
          .update({ comment })
          .eq('post_slug', slug)
          .eq('session_id', sessionId)
      }
      notHelpful?.classList.add('hidden')
      thanks?.classList.remove('hidden')
    })

    skipComment?.addEventListener('click', () => {
      notHelpful?.classList.add('hidden')
      thanks?.classList.remove('hidden')
    })
  }
</script>
