---
import CookieConsent from '../components/CookieConsent.astro'
import '../styles/theme.css'

interface Props {
  title: string
  description?: string
  image?: string
  canonicalUrl?: string
}

const { title, description, image, canonicalUrl } = Astro.props
const fullTitle = title.includes('Yaya') ? title : `${title} | Yaya Baby`

// GA4 measurement ID via env var. Se não estiver definido (dev local sem
// .env configurado), o script é completamente omitido.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0d0a27" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafe" media="(prefers-color-scheme: light)" />
    <meta name="robots" content="index, follow" />

    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    {image && <meta property="og:image" content={image} />}
    <meta property="og:site_name" content="Yaya Baby" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Manrope (display/headlines) + Plus Jakarta Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {GA_ID && (
      <>
        <!-- Google Consent Mode v2 — default denied até o usuário consentir -->
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          window.gtag = gtag;

          // Lê consentimento salvo. Default denied se nunca consentiu ou analytics=false.
          var __consent = { analytics: false };
          try {
            var saved = localStorage.getItem('yb_consent_v1');
            if (saved) {
              var parsed = JSON.parse(saved);
              if (parsed && parsed.version === 1) __consent = parsed;
            }
          } catch(e) {}

          gtag('consent', 'default', {
            analytics_storage: __consent.analytics ? 'granted' : 'denied',
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            wait_for_update: 500,
          });
          gtag('js', new Date());
        </script>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ gaId: GA_ID }}>
          gtag('config', gaId, { send_page_view: true });
        </script>
      </>
    )}
  </head>
  <body class="bg-yaya-night text-yaya-cloud font-sans antialiased min-h-screen flex flex-col">
    <!-- Smart banner: convite calmo pra baixar o app -->
    <div class="bg-yaya-purple/10 border-b border-yaya-purple/20 py-2.5 px-4 flex items-center justify-between gap-3 text-sm">
      <span class="text-yaya-cloud/90">Acompanhe a rotina do seu bebê com o Yaya</span>
      <a
        href="https://yayababy.app"
        class="shrink-0 bg-yaya-purple text-yaya-night font-display font-bold text-xs px-3 py-1.5 rounded-md hover:bg-yaya-glow transition-colors"
      >
        Baixar grátis
      </a>
    </div>

    <!-- Header -->
    <header class="border-b border-yaya-cloud/5 bg-yaya-night/90 backdrop-blur-sm sticky top-0 z-10">
      <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5" aria-label="Yaya Baby — Blog">
          <img
            src="/logo.png"
            alt="Yaya"
            class="h-7 w-auto"
            width="120"
            height="28"
          />
          <span class="text-yaya-cloud/50 font-sans text-sm">/ blog</span>
        </a>
        <a
          href="https://yayababy.app"
          class="text-sm text-yaya-purple hover:text-yaya-glow transition-colors font-sans font-medium"
        >
          Abrir app →
        </a>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-yaya-cloud/5 mt-20 py-10 px-4 text-center">
      <div class="max-w-2xl mx-auto">
        <img
          src="/symbol.png"
          alt="Yaya"
          class="h-8 w-auto mx-auto mb-4 opacity-50"
          width="32"
          height="32"
        />
        <p class="text-yaya-cloud/60 text-sm mb-2 font-sans">
          <a href="/" class="hover:text-yaya-cloud transition-colors">Yaya Baby Blog</a>
          {' · '}
          <a href="https://yayababy.app" class="hover:text-yaya-cloud transition-colors">Abrir app</a>
          {' · '}
          <a href="https://yayababy.app/privacidade" class="hover:text-yaya-cloud transition-colors">Privacidade</a>
          {' · '}
          <button
            type="button"
            onclick="window.ybOpenCookiePrefs && window.ybOpenCookiePrefs()"
            class="hover:text-yaya-cloud transition-colors underline-offset-2 hover:underline cursor-pointer"
          >
            Preferências de cookies
          </button>
        </p>
        <p class="text-xs text-yaya-cloud/40 font-sans leading-relaxed max-w-md mx-auto">
          Conteúdo educativo que acolhe sem substituir orientação médica. Consulte sempre o pediatra do seu bebê.
        </p>
      </div>
    </footer>

    <CookieConsent />
  </body>
</html>
