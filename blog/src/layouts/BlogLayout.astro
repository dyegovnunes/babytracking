---
import CookieConsent from '../components/CookieConsent.astro'
import Analytics from '@vercel/analytics/astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import HeaderAuthButton from '../components/HeaderAuthButton'
import '../styles/theme.css'

interface Props {
  title: string
  description?: string
  image?: string
  canonicalUrl?: string
  noIndex?: boolean
}

const { title, description, image, canonicalUrl, noIndex = false } = Astro.props
const fullTitle = title.includes('Yaya') ? title : `${title} | Yaya Baby`

// GA4 measurement ID via env var. Se não estiver definido (dev local sem
// .env configurado), o script é completamente omitido.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0d0a27" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafe" media="(prefers-color-scheme: light)" />

    <!-- Aplica tema salvo no localStorage antes do first paint pra evitar flash -->
    <script is:inline>
      (function() {
        try {
          var saved = localStorage.getItem('yb_theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.classList.add('theme-' + saved);
          }
        } catch(e) {}
      })();
    </script>
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />

    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    {image && <meta property="og:image" content={image} />}
    <meta property="og:site_name" content="Yaya Baby" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Manrope (display/headlines) + Plus Jakarta Sans (body) — Fraunces carregado só no reader -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {GA_ID && (
      <>
        <!-- Google Consent Mode v2 — default denied até o usuário consentir -->
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          window.gtag = gtag;

          // Lê consentimento salvo. Default denied se nunca consentiu ou analytics=false.
          var __consent = { analytics: false };
          try {
            var saved = localStorage.getItem('yb_consent_v1');
            if (saved) {
              var parsed = JSON.parse(saved);
              if (parsed && parsed.version === 1) __consent = parsed;
            }
          } catch(e) {}

          gtag('consent', 'default', {
            analytics_storage: __consent.analytics ? 'granted' : 'denied',
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            wait_for_update: 500,
          });
          gtag('js', new Date());
        </script>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ gaId: GA_ID }}>
          gtag('config', gaId, { send_page_view: true });
        </script>
      </>
    )}
  </head>
  <body class="bg-yaya-night text-yaya-cloud font-sans antialiased min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b border-yaya-cloud/5 bg-yaya-night/90 backdrop-blur-sm sticky top-0 z-20">
      <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between gap-3">
        <a href="/" class="flex items-center gap-2 min-w-0 shrink-0" aria-label="Yaya Baby — Blog">
          <img
            src="/heart.png"
            alt=""
            class="h-7 w-7 shrink-0"
            width="28"
            height="28"
          />
          <span class="font-display text-lg font-extrabold tracking-tight whitespace-nowrap">
            <span class="text-yaya-cloud">Ya</span><span class="text-yaya-purple">ya</span>
            <span class="text-yaya-purple font-bold ml-1 hidden min-[400px]:inline">blog</span>
          </span>
        </a>

        <!-- Nav links — visíveis a partir de md (768px) -->
        <nav class="hidden md:flex items-center gap-1 text-xs font-sans" aria-label="Navegação principal">
          <a href="/" class="px-2.5 py-1.5 text-yaya-cloud/55 hover:text-yaya-purple transition-colors whitespace-nowrap">
            Posts
          </a>
          <span aria-hidden="true" class="text-yaya-cloud/25 select-none">·</span>
          <a href="/biblioteca-yaya" class="px-2.5 py-1.5 text-yaya-cloud/55 hover:text-yaya-purple transition-colors whitespace-nowrap">
            Biblioteca Yaya
          </a>
          <span aria-hidden="true" class="text-yaya-cloud/25 select-none">·</span>
          <a href="https://yayababy.app?utm_source=blog&utm_medium=nav&utm_campaign=conheca_app" class="px-2.5 py-1.5 text-yaya-cloud/55 hover:text-yaya-purple transition-colors whitespace-nowrap">
            Conheça o app
          </a>
          <span aria-hidden="true" class="text-yaya-cloud/25 select-none">·</span>
          <HeaderAuthButton client:only="react" />
        </nav>

        <div class="flex items-center gap-2">
          <!-- CTAs desktop (sm+) -->
          <a
            href="/minha-biblioteca"
            class="hidden sm:inline-block border border-yaya-purple/50 text-yaya-purple hover:bg-yaya-purple/10 font-display font-bold text-xs px-4 py-2 rounded-md transition-colors whitespace-nowrap"
          >
            Minha biblioteca
          </a>
          <a
            href="https://yayababy.app?utm_source=blog&utm_medium=header&utm_campaign=download_cta"
            class="hidden sm:inline-block bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold text-xs px-4 py-2 rounded-md transition-colors whitespace-nowrap"
          >
            Baixar app
          </a>

          <!-- Hambúrguer mobile -->
          <button
            id="yb-nav-toggle"
            class="sm:hidden p-2 -mr-1 text-yaya-cloud/65 hover:text-yaya-cloud transition-colors"
            aria-label="Abrir menu"
            aria-expanded="false"
            aria-controls="yb-mobile-nav"
          >
            <svg id="yb-icon-menu" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <rect y="3" width="20" height="2" rx="1"/>
              <rect y="9" width="20" height="2" rx="1"/>
              <rect y="15" width="20" height="2" rx="1"/>
            </svg>
            <svg id="yb-icon-close" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="hidden">
              <path d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"/>
            </svg>
          </button>

          <ThemeToggle />
        </div>
      </div>

      <!-- Menu mobile expandível -->
      <div
        id="yb-mobile-nav"
        class="hidden sm:hidden border-t border-yaya-cloud/5 px-4 pb-4 pt-2 flex flex-col gap-0.5"
      >
        <a href="/" class="py-2.5 px-3 rounded-md text-sm font-sans text-yaya-cloud/70 hover:text-yaya-purple hover:bg-yaya-cloud/5 transition-colors">
          Posts
        </a>
        <a href="/biblioteca-yaya" class="py-2.5 px-3 rounded-md text-sm font-sans text-yaya-cloud/70 hover:text-yaya-purple hover:bg-yaya-cloud/5 transition-colors">
          Biblioteca Yaya
        </a>
        <a href="https://yayababy.app" class="py-2.5 px-3 rounded-md text-sm font-sans text-yaya-cloud/70 hover:text-yaya-purple hover:bg-yaya-cloud/5 transition-colors">
          Conheça o app
        </a>
        <a href="/minha-biblioteca" class="py-2.5 px-3 rounded-md text-sm font-sans text-yaya-cloud/70 hover:text-yaya-purple hover:bg-yaya-cloud/5 transition-colors">
          Entrar na biblioteca
        </a>
        <div class="mt-3 pt-3 border-t border-yaya-cloud/5 flex gap-2">
          <a
            href="/minha-biblioteca"
            class="flex-1 text-center border border-yaya-purple/50 text-yaya-purple hover:bg-yaya-purple/10 font-display font-bold text-xs px-4 py-2.5 rounded-md transition-colors"
          >
            Minha biblioteca
          </a>
          <a
            href="https://yayababy.app?utm_source=blog&utm_medium=mobile_menu&utm_campaign=download_cta"
            class="flex-1 text-center bg-yaya-purple hover:bg-yaya-glow text-yaya-night font-display font-bold text-xs px-4 py-2.5 rounded-md transition-colors"
          >
            Baixar app
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-yaya-cloud/5 mt-20 py-10 px-4 text-center">
      <div class="max-w-2xl mx-auto">
        <img
          src="/symbol.png"
          alt="Yaya"
          class="h-8 w-auto mx-auto mb-4 opacity-50"
          width="32"
          height="32"
        />
        <p class="text-yaya-cloud/60 text-sm mb-2 font-sans">
          <a href="/" class="hover:text-yaya-cloud transition-colors">Yaya Baby Blog</a>
          {' · '}
          <a href="https://yayababy.app" class="hover:text-yaya-cloud transition-colors">Abrir app</a>
          {' · '}
          <a href="https://yayababy.app/privacidade" class="hover:text-yaya-cloud transition-colors">Privacidade</a>
          {' · '}
          <button
            type="button"
            onclick="window.ybOpenCookiePrefs && window.ybOpenCookiePrefs()"
            class="hover:text-yaya-cloud transition-colors underline-offset-2 hover:underline cursor-pointer"
          >
            Preferências de cookies
          </button>
        </p>
        <p class="text-xs text-yaya-cloud/40 font-sans leading-relaxed max-w-md mx-auto">
          Conteúdo educativo que acolhe sem substituir orientação médica. Consulte sempre o pediatra do seu bebê.
        </p>
      </div>
    </footer>

    <CookieConsent />
    <Analytics />

    <!-- Toggle do menu mobile -->
    <script is:inline>
      (function () {
        var btn = document.getElementById('yb-nav-toggle')
        var menu = document.getElementById('yb-mobile-nav')
        var iconMenu = document.getElementById('yb-icon-menu')
        var iconClose = document.getElementById('yb-icon-close')
        if (!btn || !menu) return

        function setOpen(open) {
          menu.classList.toggle('hidden', !open)
          btn.setAttribute('aria-expanded', String(open))
          iconMenu.classList.toggle('hidden', open)
          iconClose.classList.toggle('hidden', !open)
        }

        btn.addEventListener('click', function () {
          setOpen(menu.classList.contains('hidden'))
        })

        // Fecha ao clicar em qualquer link do menu
        menu.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () { setOpen(false) })
        })
      })()
    </script>
  </body>
</html>
