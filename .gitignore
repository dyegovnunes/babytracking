# Dependencies
node_modules/

# Build output
dist/
build/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Cache
.cache/
.eslintcache

# Claude local settings
.claude/settings.local.json

.vercel

# Mobile build artifacts (shouldn't be committed).
# Convention: todos os builds (AAB, APK, IPA) ficam em build/ na raiz.
*.aab
*.apk
*.ipa

# Asset backups (PNGs originais etc.) — mantemos só os otimizados
# versionados. Originais ficam em pastas /backup/ locais.
**/backup/

# Test-output PDFs in root (e.g. yaya-guto-2026-04-12.pdf)
/*.pdf

# Word/Office temp lock files
~$*
